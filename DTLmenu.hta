<html>
<head>
<meta charset="UTF-8">
<title>DTLmenu v1.0-5 -- Suite DTL</title>
<HTA:APPLICATION
  APPLICATIONNAME="DTLmenu"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="normal"
  SCROLL="auto"
  BORDER="thin"
/>
<style>
  html { overflow-x: hidden; }

  body {
    background: #090d12;
    font-family: "Courier New", Courier, monospace;
    font-size: 14px;
    margin: 0;
    padding: 0;
    color: #c9d1d9;
    overflow-x: hidden;
  }

  .dtl-wrap {
    width: auto;
    background: #0d1117;
    border: 1px solid #30363d;
  }

  .dtl-body { padding: 20px 24px 28px; }

  .dtl-brand {
    width: 100%;
    margin: 0 0 18px;
    border-bottom: 1px solid #21262d;
    border-collapse: collapse;
  }
  .dtl-brand-text {
    vertical-align: top;
    padding: 0 0 16px;
  }
  .dtl-brand-title {
    color: #c9d1d9;
    font-size: 16px;
    line-height: 16px;
    font-weight: bold;
    margin: 0;
  }
  .dtl-brand-subtitle {
    color: #8b949e;
    font-size: 12px;
    line-height: 15px;
    margin: 0;
  }
  .dtl-brand-website {
    color: #58a6ff;
    font-size: 12px;
    line-height: 16px;
    margin: 0;
  }
  .dtl-brand-logo {
    vertical-align: top;
    text-align: right;
    padding: 0 48px 16px 24px;
  }
  .dtl-brand-logo img {
    display: block;
    width: 135px;
    height: 47px;
    border: 0;
  }

  .dtl-header { color: #00ff00; font-size: 16px; margin: 0 0 4px; }
  .dtl-sub    { color: #444c56; font-size: 12px; margin: 0 0 14px; }
  .dtl-sep    { border: none; border-top: 1px solid #21262d; margin: 0 0 16px; }

  .dtl-section-label {
    color: #6e7681;
    font-size: 12px;
    text-transform: uppercase;
    margin: 0 0 8px;
    display: block;
  }

  .dtl-grid-wrap  { margin-bottom: 12px; font-size: 0; }
  .dtl-grid-wrap .dtl-btn {
    display: inline-block;
    width: 49%;
    vertical-align: top;
    margin-bottom: 6px;
    font-size: 14px;
  }
  .dtl-grid-wrap .dtl-btn:nth-child(odd) { margin-right: 1%; }

  .dtl-grid3-wrap { margin-bottom: 12px; font-size: 0; }
  .dtl-grid3-wrap .dtl-btn {
    display: inline-block;
    width: 32%;
    vertical-align: top;
    margin-bottom: 6px;
    margin-right: 1%;
    font-size: 14px;
  }
  .dtl-grid3-wrap .dtl-btn:last-child { margin-right: 0; }

  .dtl-grid1-wrap { margin-bottom: 12px; }
  .dtl-grid1-wrap .dtl-btn { display: block; width: 100%; font-size: 14px; }

  .dtl-btn {
    background: #161b22;
    border: 1px solid #30363d;
    padding: 12px 14px;
    cursor: pointer;
    text-align: left;
    font-family: "Courier New", Courier, monospace;
    color: #c9d1d9;
    box-sizing: border-box;
  }
  .dtl-btn:hover  { border-color: #1a6bbf; background: #0d1f33; }
  .dtl-btn-num   { color: #1a6bbf; font-size: 16px; font-weight: bold; }
  .dtl-btn-sub   { color: #6e7681; font-size: 12px; display: block; margin-top: 3px; }
  .dtl-tag {
    font-size: 11px;
    padding: 1px 6px;
    font-family: "Courier New", Courier, monospace;
    border: 1px solid #3d4499;
    background: #1a1a3d;
    color: #9ea6f5;
  }
  .dtl-tag-py  { border: 1px solid #1a6bbf; background: #001a33; color: #58a6ff; }

  .dtl-btn-quit   { border-color: #3d1a1a; }
  .dtl-btn-quit:hover { border-color: #e24b4a; background: #1a0000; }
  .dtl-btn-quit .dtl-btn-num { color: #e24b4a; }

  .dtl-info-box {
    background: #161b22;
    border: 1px solid #21262d;
    border-left: 3px solid #1a6bbf;
    padding: 14px 16px;
    margin-top: 12px;
    font-size: 14px;
  }
  .dtl-info-line { color: #8b949e; line-height: 2.0; }
  .key   { color: #1a6bbf; }
  .val   { color: #c9d1d9; }
  .ipath { color: #00ff00; font-size: 13px; }

  .dtl-cmd-box {
    background: #0a0d10;
    border: 1px solid #21262d;
    padding: 12px 14px;
    margin-top: 12px;
  }
  .dtl-cmd-title { color: #00ff00; margin-bottom: 10px; font-size: 14px; }
  .dtl-cmd-line    { color: #58a6ff; line-height: 2.0; display: block; font-size: 13px; }
  .dtl-cmd-comment { color: #444c56; line-height: 2.0; display: block; font-size: 13px; }
  .dtl-cmd-echo    { color: #8b949e; line-height: 2.0; display: block; font-size: 13px; }

  .dtl-run-btn {
    float: right;
    background: #001a00;
    border: 1px solid #00ff00;
    color: #00ff00;
    font-size: 13px;
    padding: 3px 12px;
    cursor: pointer;
    font-family: "Courier New", Courier, monospace;
  }
  .dtl-run-btn:hover { background: #003300; }

  .dtl-folder-btn {
    background: none;
    border: 1px solid #21262d;
    color: #58a6ff;
    font-size: 12px;
    padding: 2px 10px;
    cursor: pointer;
    font-family: "Courier New", Courier, monospace;
    margin-left: 8px;
  }
  .dtl-folder-btn:hover { color: #c9d1d9; border-color: #8b949e; }

  .dtl-back {
    background: none;
    border: 1px solid #21262d;
    color: #6e7681;
    font-size: 13px;
    padding: 6px 14px;
    cursor: pointer;
    font-family: "Courier New", Courier, monospace;
    margin-top: 16px;
    display: inline-block;
  }
  .dtl-back:hover { color: #c9d1d9; border-color: #444c56; }

  .screen { display: none; }
  .screen-active { display: block; }

  .dtl-config {
    background: #0a0d10;
    border: 1px solid #21262d;
    border-left: 3px solid #00ff00;
    padding: 10px 14px;
    margin-bottom: 18px;
    font-size: 14px;
    color: #6e7681;
  }
  .dtl-config label { color: #8b949e; }
  .dtl-config input {
    background: #161b22;
    border: 1px solid #30363d;
    color: #00ff00;
    font-family: "Courier New", Courier, monospace;
    font-size: 14px;
    padding: 4px 8px;
    width: 78%;
  }
  .dtl-config-btn {
    background: none;
    border: 1px solid #30363d;
    color: #6e7681;
    font-size: 13px;
    padding: 4px 12px;
    cursor: pointer;
    font-family: "Courier New", Courier, monospace;
    margin-left: 8px;
  }
  .dtl-config-btn:hover { color: #00ff00; border-color: #00ff00; }
</style>
</head>
<body>

<div class="dtl-wrap">
  <div class="dtl-body">

    <table class="dtl-brand" cellspacing="0" cellpadding="0">
      <tr>
        <td class="dtl-brand-text">
          <p class="dtl-brand-title">DTLmenu v1.0-5</p>
          <p class="dtl-brand-subtitle">Lanceur de compilation de la suite NetDTL</p>
          <p class="dtl-brand-website">www.netdtl.com</p>
        </td>
        <td class="dtl-brand-logo">
          <img src="../NetDTL_Web_Site/netdtl_logo_small.png" alt="NetDTL">
        </td>
      </tr>
    </table>

    <div class="dtl-config">
      <label>ROOT_DIR&nbsp;&nbsp;</label>
      <input type="text" id="root-dir" value="">
      <button class="dtl-config-btn" onclick="applyRoot()">appliquer</button>
      <button class="dtl-config-btn" onclick="chooseRoot()">parcourir</button>
      <div class="dtl-info-line" id="root-status"></div>
      <div class="dtl-info-line" id="pyinstaller-status"></div>
    </div>

    <!-- MAIN MENU -->
    <div id="screen-main" class="screen-active">
      <span class="dtl-section-label">Compilation individuelle</span>
      <div class="dtl-grid-wrap">
        <button class="dtl-btn" onclick="show('dtlknowswhy')">
          <span class="dtl-btn-num">1</span>&nbsp;
          DTLknowsWhy <span class="dtl-tag dtl-tag-py">Python</span>
          <span class="dtl-btn-sub">+ CLI + Agent</span>
        </button>
        <button class="dtl-btn" onclick="show('dtlsayswhat')">
          <span class="dtl-btn-num">2</span>&nbsp;
          DTLsaysWhat <span class="dtl-tag dtl-tag-py">Python</span>
          <span class="dtl-btn-sub">onefile console</span>
        </button>
        <button class="dtl-btn" onclick="show('gitdtl')">
          <span class="dtl-btn-num">3</span>&nbsp;
          GitDTL <span class="dtl-tag dtl-tag-py">Python</span>
          <span class="dtl-btn-sub">Tkinter GUI</span>
        </button>
        <button class="dtl-btn" onclick="show('githubmenu')">
          <span class="dtl-btn-num">4</span>&nbsp;
          GitHubMenu <span class="dtl-tag dtl-tag-py">Python</span>
          <span class="dtl-btn-sub">Tkinter GUI</span>
        </button>
        <button class="dtl-btn" onclick="show('dtlaudit')">
          <span class="dtl-btn-num">5</span>&nbsp;
          DTLaudit <span class="dtl-tag dtl-tag-py">Python</span>
          <span class="dtl-btn-sub">onefile console</span>
        </button>
        <button class="dtl-btn" onclick="show('dt4u')">
          <span class="dtl-btn-num">6</span>&nbsp;
          DTL4u <span class="dtl-tag dtl-tag-py">Python</span>
          <span class="dtl-btn-sub">Tkinter GUI</span>
        </button>
        <button class="dtl-btn" onclick="show('dtlarchive')">
          <span class="dtl-btn-num">7</span>&nbsp;
          DTLarchive <span class="dtl-tag dtl-tag-py">Python</span>
          <span class="dtl-btn-sub">onefile console</span>
        </button>
        <button class="dtl-btn" onclick="show('dtli18n')">
          <span class="dtl-btn-num">I</span>&nbsp;
          DTLi18n <span class="dtl-tag dtl-tag-py">Python</span>
          <span class="dtl-btn-sub">onefile console</span>
        </button>
      </div>

      <span class="dtl-section-label">Actions globales</span>
      <div class="dtl-grid3-wrap">
        <button class="dtl-btn" onclick="show('all')">
          <span class="dtl-btn-num">A</span>&nbsp;
          Tous les outils Python
          <span class="dtl-btn-sub">Build complet</span>
        </button>
        <button class="dtl-btn" onclick="show('folders')">
          <span class="dtl-btn-num">8</span>&nbsp;
          Ouvrir un dossier
          <span class="dtl-btn-sub">Chemins dist\</span>
        </button>
        <button class="dtl-btn" onclick="show('pyinstaller')">
          <span class="dtl-btn-num">9</span>&nbsp;
          Vérifier PyInstaller
          <span class="dtl-btn-sub">Environnement</span>
        </button>
      </div>

      <div class="dtl-grid1-wrap">
        <button class="dtl-btn dtl-btn-quit" onclick="window.close()">
          <span class="dtl-btn-num">0</span>&nbsp; Quitter
        </button>
      </div>
    </div>

    <!-- DTLknowsWhy -->
    <div id="screen-dtlknowswhy" class="screen">
      <p class="dtl-header">Compilation DTLknowsWhy</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-dkw','Compilation DTLknowsWhy')">&#9654; exécuter</button>
          DTLknowsWhy.exe &bull; DTLknowsWhy-CLI.exe &bull; DTLknowsWhy-Agent.exe
        </div>
        <div id="blk-dkw">
          <span class="dtl-cmd-line" id="dkw_1"></span>
          <span class="dtl-cmd-line" id="dkw_2"></span>
          <span class="dtl-cmd-line" id="dkw_3"></span>
          <span class="dtl-cmd-line" id="dkw_4"></span>
          <span class="dtl-cmd-line" id="dkw_5"></span>
          <span class="dtl-cmd-line" id="dkw_6"></span>
          <span class="dtl-cmd-line" id="dkw_7"></span>
          <span class="dtl-cmd-echo" id="dkw_8"></span>
          <span class="dtl-cmd-echo" id="dkw_9"></span>
          <span class="dtl-cmd-echo" id="dkw_10"></span>
          <span class="dtl-cmd-echo" id="dkw_11"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- DTLsaysWhat -->
    <div id="screen-dtlsayswhat" class="screen">
      <p class="dtl-header">Compilation DTLsaysWhat</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-dsw','Compilation DTLsaysWhat')">&#9654; exécuter</button>
          DTLsaysWhat.exe
        </div>
        <div id="blk-dsw">
          <span class="dtl-cmd-line" id="dsw_1"></span>
          <span class="dtl-cmd-line" id="dsw_2"></span>
          <span class="dtl-cmd-line" id="dsw_3"></span>
          <span class="dtl-cmd-line" id="dsw_4"></span>
          <span class="dtl-cmd-echo" id="dsw_5"></span>
          <span class="dtl-cmd-echo" id="dsw_6"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- GitDTL -->
    <div id="screen-gitdtl" class="screen">
      <p class="dtl-header">Compilation GitDTL</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-gdtl','Compilation GitDTL')">&#9654; exécuter</button>
          GitDTL.exe
        </div>
        <div id="blk-gdtl">
          <span class="dtl-cmd-line" id="gdtl_1"></span>
          <span class="dtl-cmd-line" id="gdtl_2"></span>
          <span class="dtl-cmd-line" id="gdtl_3"></span>
          <span class="dtl-cmd-echo" id="gdtl_4"></span>
          <span class="dtl-cmd-echo" id="gdtl_5"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- GitHubMenu -->
    <div id="screen-githubmenu" class="screen">
      <p class="dtl-header">Compilation GitHubMenu</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-ghm','Compilation GitHubMenu')">&#9654; exécuter</button>
          GitHubMenu.exe
        </div>
        <div id="blk-ghm">
          <span class="dtl-cmd-line" id="ghm_1"></span>
          <span class="dtl-cmd-line" id="ghm_2"></span>
          <span class="dtl-cmd-line" id="ghm_3"></span>
          <span class="dtl-cmd-echo" id="ghm_4"></span>
          <span class="dtl-cmd-echo" id="ghm_5"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- DTLaudit -->
    <div id="screen-dtlaudit" class="screen">
      <p class="dtl-header">Compilation DTLaudit</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-dta','Compilation DTLaudit')">&#9654; exécuter</button>
          DTLaudit.exe
        </div>
        <div id="blk-dta">
          <span class="dtl-cmd-line" id="dta_1"></span>
          <span class="dtl-cmd-line" id="dta_2"></span>
          <span class="dtl-cmd-line" id="dta_3"></span>
          <span class="dtl-cmd-echo" id="dta_4"></span>
          <span class="dtl-cmd-echo" id="dta_5"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- DTL4u -->
    <div id="screen-dt4u" class="screen">
      <p class="dtl-header">Compilation DTL4u</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-dt4u','Compilation DTL4u')">&#9654; exécuter</button>
          DTL4u.exe
        </div>
        <div id="blk-dt4u">
          <span class="dtl-cmd-line" id="dt4u_1"></span>
          <span class="dtl-cmd-line" id="dt4u_2"></span>
          <span class="dtl-cmd-line" id="dt4u_3"></span>
          <span class="dtl-cmd-echo" id="dt4u_4"></span>
          <span class="dtl-cmd-echo" id="dt4u_5"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- DTLarchive -->
    <div id="screen-dtlarchive" class="screen">
      <p class="dtl-header">Compilation DTLarchive</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-dtlar','Compilation DTLarchive')">&#9654; exécuter</button>
          DTLarchive.exe
        </div>
        <div id="blk-dtlar">
          <span class="dtl-cmd-line" id="dtlar_1"></span>
          <span class="dtl-cmd-line" id="dtlar_2"></span>
          <span class="dtl-cmd-line" id="dtlar_3"></span>
          <span class="dtl-cmd-echo" id="dtlar_4"></span>
          <span class="dtl-cmd-echo" id="dtlar_5"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- DTLi18n -->
    <div id="screen-dtli18n" class="screen">
      <p class="dtl-header">Compilation DTLi18n</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-dtli18n','Compilation DTLi18n')">&#9654; exécuter</button>
          DTLi18n.exe
        </div>
        <div id="blk-dtli18n">
          <span class="dtl-cmd-line" id="dtli18n_1"></span>
          <span class="dtl-cmd-line" id="dtli18n_2"></span>
          <span class="dtl-cmd-line" id="dtli18n_3"></span>
          <span class="dtl-cmd-echo" id="dtli18n_4"></span>
          <span class="dtl-cmd-echo" id="dtli18n_5"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- Build all -->
    <div id="screen-all" class="screen">
      <p class="dtl-header">Compilation complète &mdash; outils Python DTL</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-all','Compilation des outils Python DTL')">&#9654; exécuter</button>
          DTLknowsWhy + DTLsaysWhat + GitDTL + GitHubMenu + DTLaudit + DTL4u + DTLarchive + DTLi18n
        </div>
        <div id="blk-all">
          <span class="dtl-cmd-comment">--- DTLknowsWhy ---</span>
          <span class="dtl-cmd-line" id="all_1"></span>
          <span class="dtl-cmd-line" id="all_2"></span>
          <span class="dtl-cmd-line" id="all_3"></span>
          <span class="dtl-cmd-line" id="all_4"></span>
          <span class="dtl-cmd-line" id="all_5"></span>
          <span class="dtl-cmd-line" id="all_6"></span>
          <span class="dtl-cmd-line" id="all_7"></span>
          <span class="dtl-cmd-comment">--- DTLsaysWhat ---</span>
          <span class="dtl-cmd-line" id="all_8"></span>
          <span class="dtl-cmd-line" id="all_9"></span>
          <span class="dtl-cmd-line" id="all_10"></span>
          <span class="dtl-cmd-line" id="all_11"></span>
          <span class="dtl-cmd-comment">--- GitDTL ---</span>
          <span class="dtl-cmd-line" id="all_12"></span>
          <span class="dtl-cmd-line" id="all_13"></span>
          <span class="dtl-cmd-line" id="all_14"></span>
          <span class="dtl-cmd-comment">--- GitHubMenu ---</span>
          <span class="dtl-cmd-line" id="all_15"></span>
          <span class="dtl-cmd-line" id="all_16"></span>
          <span class="dtl-cmd-line" id="all_17"></span>
          <span class="dtl-cmd-comment">--- DTLaudit ---</span>
          <span class="dtl-cmd-line" id="all_18"></span>
          <span class="dtl-cmd-line" id="all_19"></span>
          <span class="dtl-cmd-line" id="all_20"></span>
          <span class="dtl-cmd-comment">--- DTL4u ---</span>
          <span class="dtl-cmd-line" id="all_21"></span>
          <span class="dtl-cmd-line" id="all_22"></span>
          <span class="dtl-cmd-line" id="all_23"></span>
          <span class="dtl-cmd-comment">--- DTLarchive ---</span>
          <span class="dtl-cmd-line" id="all_24"></span>
          <span class="dtl-cmd-line" id="all_25"></span>
          <span class="dtl-cmd-line" id="all_26"></span>
          <span class="dtl-cmd-comment">--- DTLi18n ---</span>
          <span class="dtl-cmd-line" id="all_27"></span>
          <span class="dtl-cmd-line" id="all_28"></span>
          <span class="dtl-cmd-line" id="all_29"></span>
          <span class="dtl-cmd-echo" id="all_30"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- Folders -->
    <div id="screen-folders" class="screen">
      <p class="dtl-header">Dossiers d'exécutables</p>
      <hr class="dtl-sep">
      <div class="dtl-info-box">
        <div class="dtl-info-line"><span class="key">1 </span><span class="ipath" id="f-dkw"></span> <button class="dtl-folder-btn" onclick="openFolder('dkw')">ouvrir</button></div>
        <div class="dtl-info-line"><span class="key">2 </span><span class="ipath" id="f-dsw"></span> <button class="dtl-folder-btn" onclick="openFolder('dsw')">ouvrir</button></div>
        <div class="dtl-info-line"><span class="key">3 </span><span class="ipath" id="f-gdtl"></span> <button class="dtl-folder-btn" onclick="openFolder('gdtl')">ouvrir</button></div>
        <div class="dtl-info-line"><span class="key">4 </span><span class="ipath" id="f-ghm"></span> <button class="dtl-folder-btn" onclick="openFolder('ghm')">ouvrir</button></div>
        <div class="dtl-info-line"><span class="key">5 </span><span class="ipath" id="f-dta"></span> <button class="dtl-folder-btn" onclick="openFolder('dta')">ouvrir</button></div>
        <div class="dtl-info-line"><span class="key">6 </span><span class="ipath" id="f-dt4u"></span> <button class="dtl-folder-btn" onclick="openFolder('dt4u')">ouvrir</button></div>
        <div class="dtl-info-line"><span class="key">7 </span><span class="ipath" id="f-dtlar"></span> <button class="dtl-folder-btn" onclick="openFolder('dtlar')">ouvrir</button></div>
        <div class="dtl-info-line"><span class="key">I </span><span class="ipath" id="f-dtli18n"></span> <button class="dtl-folder-btn" onclick="openFolder('dtli18n')">ouvrir</button></div>
        <div class="dtl-info-line"><span class="key">8 </span><span class="ipath" id="f-root"></span> <button class="dtl-folder-btn" onclick="openFolder('root')">ouvrir</button></div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

    <!-- PyInstaller -->
    <div id="screen-pyinstaller" class="screen">
      <p class="dtl-header">Vérification PyInstaller</p>
      <hr class="dtl-sep">
      <div class="dtl-cmd-box">
        <div class="dtl-cmd-title">
          <button class="dtl-run-btn" onclick="runBlock('blk-pyi','Vérification PyInstaller')">&#9654; exécuter</button>
          Environnement Python / PyInstaller
        </div>
        <div id="blk-pyi">
          <span class="dtl-cmd-line" id="pyi_1"></span>
          <span class="dtl-cmd-line" id="pyi_2"></span>
          <span class="dtl-cmd-line" id="pyi_3"></span>
          <span class="dtl-cmd-echo" id="pyi_4"></span>
        </div>
      </div>
      <button class="dtl-back" onclick="show('main')">&lt; retour au menu</button>
    </div>

  </div>
</div>

<script language="JScript">

var REQUIRED_TOOLS = ['DTLKnowsWhy', 'DTLsaysWhat', 'GitDTL', 'GitHubMenu', 'DTLaudit', 'DTL4u', 'DTLarchive', 'DTLi18n'];

function sizeApplicationWindow() {
  var targetWidth = Math.min(1500, screen.availWidth);
  var targetHeight = Math.min(850, screen.availHeight);
  window.resizeTo(targetWidth, targetHeight);
  window.moveTo(
    Math.max(0, Math.round((screen.availWidth - targetWidth) / 2)),
    Math.max(0, Math.round((screen.availHeight - targetHeight) / 2))
  );
}

function getFso() {
  return new ActiveXObject('Scripting.FileSystemObject');
}

function getShell() {
  return new ActiveXObject('WScript.Shell');
}

function trimSlash(path) {
  while (path.length > 0 && (path.charAt(path.length - 1) === '\\' || path.charAt(path.length - 1) === '/')) {
    path = path.substring(0, path.length - 1);
  }
  return path;
}

function normalizePath(path) {
  path = path.replace(/\//g, '\\');
  return trimSlash(path);
}

function getAppFolder() {
  var fso = getFso();
  var path = unescape(location.pathname);
  path = path.replace(/\//g, '\\');
  if (path.charAt(0) === '\\' && path.charAt(2) === ':') {
    path = path.substring(1);
  }
  return fso.GetParentFolderName(path);
}

function getConfigPath() {
  return getAppFolder() + '\\DTLmenu.root';
}

function loadSavedRoot() {
  var fso = getFso();
  var cfg = getConfigPath();
  if (!fso.FileExists(cfg)) return '';
  var file = fso.OpenTextFile(cfg, 1, false, -1);
  var value = file.ReadAll();
  file.Close();
  return normalizePath(value.replace(/^\s+|\s+$/g, ''));
}

function saveRoot(root) {
  var fso = getFso();
  var file = fso.CreateTextFile(getConfigPath(), true, true);
  file.Write(root);
  file.Close();
}

function guessRootFromAppFolder() {
  var fso = getFso();
  var appFolder = getAppFolder();
  if (LCaseName(appFolder) === 'dtlmenu') {
    return fso.GetParentFolderName(appFolder);
  }
  return appFolder;
}

function LCaseName(path) {
  var fso = getFso();
  return fso.GetFileName(path).toLowerCase();
}

function missingRequiredTools(root) {
  var fso = getFso();
  var missing = [];
  if (!root || !fso.FolderExists(root)) {
    return ['dossier outils'];
  }
  for (var i = 0; i < REQUIRED_TOOLS.length; i++) {
    if (!fso.FolderExists(root + '\\' + REQUIRED_TOOLS[i])) {
      missing.push(REQUIRED_TOOLS[i]);
    }
  }
  return missing;
}

function isValidRoot(root) {
  return missingRequiredTools(root).length === 0;
}

function setRootStatus(text, ok) {
  var el = document.getElementById('root-status');
  if (!el) return;
  el.style.color = ok ? '#00ff00' : '#ffbd2e';
  el.innerText = text;
}

function setPyInstallerStatus(text, ok) {
  var el = document.getElementById('pyinstaller-status');
  if (!el) return;
  el.style.color = ok ? '#00ff00' : '#ffbd2e';
  el.innerText = text;
}

function commandSucceeds(commandLine) {
  var shell = getShell();
  var cmd = shell.ExpandEnvironmentStrings('%ComSpec%') + ' /c "' + commandLine + ' >nul 2>&1"';
  return shell.Run(cmd, 0, true) === 0;
}

function isPythonInstalled() {
  return commandSucceeds('python --version');
}

function isPyInstallerInstalled() {
  return commandSucceeds('python -m PyInstaller --version');
}

function runTempScript(scriptName, lines) {
  var fso = getFso();
  var shell = getShell();
  var tmp = shell.ExpandEnvironmentStrings('%TEMP%');
  var path = tmp + '\\' + scriptName;
  var file = fso.CreateTextFile(path, true, false);
  file.Write(lines.join('\r\n'));
  file.Close();
  shell.Run('"' + path + '"', 1, false);
}

function cmdText(text) {
  text = String(text);
  text = text.replace(/[àáâãäå]/g, 'a').replace(/[ÀÁÂÃÄÅ]/g, 'A');
  text = text.replace(/[èéêë]/g, 'e').replace(/[ÈÉÊË]/g, 'E');
  text = text.replace(/[ìíîï]/g, 'i').replace(/[ÌÍÎÏ]/g, 'I');
  text = text.replace(/[òóôõö]/g, 'o').replace(/[ÒÓÔÕÖ]/g, 'O');
  text = text.replace(/[ùúûü]/g, 'u').replace(/[ÙÚÛÜ]/g, 'U');
  text = text.replace(/[ç]/g, 'c').replace(/[Ç]/g, 'C');
  text = text.replace(/[œ]/g, 'oe').replace(/[Œ]/g, 'OE');
  text = text.replace(/[–—]/g, '-').replace(/[•]/g, '*');
  return text.replace(/[^\x20-\x7E]/g, '?');
}

function offerPythonInstall() {
  var answer = confirm('Python est introuvable.\n\nVoulez-vous lancer son installation avec winget ?\n\nCommande : winget install --id Python.Python.3.12 -e --source winget');
  if (!answer) return false;
  runTempScript('DTLmenu_install_python.cmd', [
    '@echo off',
    'title Installation Python',
    'echo Installation de Python avec winget',
    'echo ================================================================',
    'winget install --id Python.Python.3.12 -e --source winget',
    'echo.',
    'echo Si Python vient d\'etre installe, fermez puis relancez DTLmenu.',
    'echo.',
    'pause'
  ]);
  return false;
}

function offerPyInstallerInstall() {
    var answer = confirm('PyInstaller est introuvable.\n\nVoulez-vous l\'installer maintenant ?\n\nCommande : python -m pip install --upgrade pyinstaller');
  if (!answer) return false;
  runTempScript('DTLmenu_install_pyinstaller.cmd', [
    '@echo off',
    'title Installation PyInstaller',
    'echo Installation de PyInstaller',
    'echo ================================================================',
    'python -m pip install --upgrade pip',
    'python -m pip install --upgrade pyinstaller',
    'echo.',
    'python -m PyInstaller --version',
    'echo.',
    'echo Si une version s\'affiche ci-dessus, PyInstaller est installe.',
    'echo Vous pouvez relancer la compilation dans DTLmenu.',
    'echo.',
    'pause'
  ]);
  return false;
}

function ensurePyInstaller() {
  if (!isPythonInstalled()) {
    setPyInstallerStatus('Python introuvable.');
    return offerPythonInstall();
  }
  if (isPyInstallerInstalled()) {
    setPyInstallerStatus('PyInstaller disponible.', true);
    return true;
  }
  setPyInstallerStatus('PyInstaller introuvable.', false);
  return offerPyInstallerInstall();
}

function browseForRoot(message) {
  var shellApp = new ActiveXObject('Shell.Application');
  var folder = shellApp.BrowseForFolder(0, message, 0, 0);
  if (!folder) return '';
  return normalizePath(folder.Self.Path);
}

function chooseRoot() {
  var root = browseForRoot('Selectionnez le dossier outils qui contient les projets DTL, dont DTLi18n.');
  if (!root) return false;
  document.getElementById('root-dir').value = root;
  return applyRoot();
}

function ensureValidRoot() {
  var input = document.getElementById('root-dir');
  var candidates = [loadSavedRoot(), guessRootFromAppFolder(), input.value];
  var root = '';

  for (var i = 0; i < candidates.length; i++) {
    if (candidates[i] && isValidRoot(candidates[i])) {
      root = normalizePath(candidates[i]);
      break;
    }
  }

  while (!root) {
    var tried = normalizePath(input.value || candidates[1] || '');
    var missing = missingRequiredTools(tried);
    var msg = 'Le dossier outils est introuvable ou incomplet.';
    if (tried) msg += '\n\nChemin teste :\n' + tried;
    msg += '\n\nElements manquants : ' + missing.join(', ');
    msg += '\n\nSelectionnez le dossier outils.';
    root = browseForRoot(msg);
    if (!root) {
      input.value = tried;
      setRootStatus('Dossier outils non configure.', false);
      renderAll();
      return false;
    }
    if (!isValidRoot(root)) {
      alert('Ce dossier ne contient pas tous les outils a reconstruire :\n\n' + missingRequiredTools(root).join('\n'));
      root = '';
    }
  }

  input.value = root;
  saveRoot(root);
  setRootStatus('Dossier outils valide : ' + root, true);
  renderAll();
  return true;
}

function getPaths() {
  var root = document.getElementById('root-dir').value;
  root = normalizePath(root);
  return {
    ROOT:  root,
    DKW:   root + '\\DTLKnowsWhy',
    DSW:   root + '\\DTLsaysWhat',
    GDTL:  root + '\\GitDTL',
    GHM:   root + '\\GitHubMenu',
    DTA:   root + '\\DTLaudit',
    DT4U:  root + '\\DTL4u',
    DTLAR: root + '\\DTLarchive',
    DTLI18N: root + '\\DTLi18n'
  };
}

function R(s) {
  var p = getPaths();
  s = s.replace(/\{ROOT\}/g,  p.ROOT);
  s = s.replace(/\{DKW\}/g,   p.DKW);
  s = s.replace(/\{DSW\}/g,   p.DSW);
  s = s.replace(/\{GDTL\}/g,  p.GDTL);
  s = s.replace(/\{GHM\}/g,   p.GHM);
  s = s.replace(/\{DTA\}/g,   p.DTA);
  s = s.replace(/\{DT4U\}/g,  p.DT4U);
  s = s.replace(/\{DTLAR\}/g, p.DTLAR);
  s = s.replace(/\{DTLI18N\}/g, p.DTLI18N);
  return s;
}

function setLine(id, tpl) {
  var el = document.getElementById(id);
  if (el) el.innerText = R(tpl);
}

function renderAll() {
  var p = getPaths();

  setLine('dkw_1',  'cd /d "{DKW}"');
  setLine('dkw_2',  'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DKW}" DTLknowsWhy');
  setLine('dkw_3',  'python -c "import psutil, win32serviceutil; print(\'Dependances DTLKnowsWhy OK\')"');
  setLine('dkw_4',  'python -m PyInstaller DTLknowsWhy.spec');
  setLine('dkw_5',  'python -m PyInstaller DTLknowsWhy-CLI.spec');
  setLine('dkw_6',  'cd /d "{DKW}\\agent"');
  setLine('dkw_7',  'python -m PyInstaller --distpath "..\\dist" --workpath "..\\build\\DTLknowsWhy-Agent" DTLknowsWhy-Agent.spec');
  setLine('dkw_8',  'Executables attendus :');
  setLine('dkw_9',  '{DKW}\\dist\\DTLknowsWhy.exe');
  setLine('dkw_10', '{DKW}\\dist\\DTLknowsWhy-CLI.exe');
  setLine('dkw_11', '{DKW}\\dist\\DTLknowsWhy-Agent.exe');

  setLine('dsw_1', 'cd /d "{DSW}"');
  setLine('dsw_2', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DSW}" DTLsaysWhat');
  setLine('dsw_3', 'python -c "import wmi, psutil; print(\'Dependances DTLsaysWhat OK\')"');
  setLine('dsw_4', 'python -m PyInstaller --onefile --console --name DTLsaysWhat DTLsaysWhat.py');
  setLine('dsw_5', 'Executable attendu :');
  setLine('dsw_6', '{DSW}\\dist\\DTLsaysWhat.exe');

  setLine('gdtl_1', 'cd /d "{GDTL}"');
  setLine('gdtl_2', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{GDTL}" GitDTL');
  setLine('gdtl_3', 'python -m PyInstaller GitDTL.spec');
  setLine('gdtl_4', 'Executable attendu :');
  setLine('gdtl_5', '{GDTL}\\dist\\GitDTL.exe');

  setLine('ghm_1', 'cd /d "{GHM}"');
  setLine('ghm_2', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{GHM}" GitHubMenu');
  setLine('ghm_3', 'python -m PyInstaller GitHubMenu.spec');
  setLine('ghm_4', 'Executable attendu :');
  setLine('ghm_5', '{GHM}\\dist\\GitHubMenu.exe');

  setLine('dta_1', 'cd /d "{DTA}"');
  setLine('dta_2', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DTA}" DTLaudit');
  setLine('dta_3', 'python -m PyInstaller --onefile --noconsole --name DTLaudit DTLaudit.py');
  setLine('dta_4', 'Executable attendu :');
  setLine('dta_5', '{DTA}\\dist\\DTLaudit.exe');

  setLine('dt4u_1', 'cd /d "{DT4U}"');
  setLine('dt4u_2', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DT4U}" DTL4u');
  setLine('dt4u_3', 'python -m PyInstaller DTL4u.spec');
  setLine('dt4u_4', 'Executable attendu :');
  setLine('dt4u_5', '{DT4U}\\dist\\DTL4u.exe');

  setLine('dtlar_1', 'cd /d "{DTLAR}"');
  setLine('dtlar_2', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DTLAR}" DTLarchive');
  setLine('dtlar_3', 'python -m PyInstaller --onefile --console --name DTLarchive DTLarchive.py');
  setLine('dtlar_4', 'Executable attendu :');
  setLine('dtlar_5', '{DTLAR}\\dist\\DTLarchive.exe');

  setLine('dtli18n_1', 'cd /d "{DTLI18N}"');
  setLine('dtli18n_2', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DTLI18N}" DTLi18n');
  setLine('dtli18n_3', 'python -m PyInstaller --onefile --console --name DTLi18n DTLi18n.py');
  setLine('dtli18n_4', 'Executable attendu :');
  setLine('dtli18n_5', '{DTLI18N}\\dist\\DTLi18n.exe');

  setLine('all_1',  'cd /d "{DKW}"');
  setLine('all_2',  'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DKW}" DTLknowsWhy');
  setLine('all_3',  'python -c "import psutil, win32serviceutil; print(\'Dependances DTLKnowsWhy OK\')"');
  setLine('all_4',  'python -m PyInstaller DTLknowsWhy.spec');
  setLine('all_5',  'python -m PyInstaller DTLknowsWhy-CLI.spec');
  setLine('all_6',  'cd /d "{DKW}\\agent"');
  setLine('all_7',  'python -m PyInstaller --distpath "..\\dist" --workpath "..\\build\\DTLknowsWhy-Agent" DTLknowsWhy-Agent.spec');
  setLine('all_8',  'cd /d "{DSW}"');
  setLine('all_9',  'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DSW}" DTLsaysWhat');
  setLine('all_10', 'python -c "import wmi, psutil; print(\'Dependances DTLsaysWhat OK\')"');
  setLine('all_11', 'python -m PyInstaller --onefile --console --name DTLsaysWhat DTLsaysWhat.py');
  setLine('all_12', 'cd /d "{GDTL}"');
  setLine('all_13', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{GDTL}" GitDTL');
  setLine('all_14', 'python -m PyInstaller GitDTL.spec');
  setLine('all_15', 'cd /d "{GHM}"');
  setLine('all_16', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{GHM}" GitHubMenu');
  setLine('all_17', 'python -m PyInstaller GitHubMenu.spec');
  setLine('all_18', 'cd /d "{DTA}"');
  setLine('all_19', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DTA}" DTLaudit');
  setLine('all_20', 'python -m PyInstaller --onefile --noconsole --name DTLaudit DTLaudit.py');
  setLine('all_21', 'cd /d "{DT4U}"');
  setLine('all_22', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DT4U}" DTL4u');
  setLine('all_23', 'python -m PyInstaller DTL4u.spec');
  setLine('all_24', 'cd /d "{DTLAR}"');
  setLine('all_25', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DTLAR}" DTLarchive');
  setLine('all_26', 'python -m PyInstaller --onefile --console --name DTLarchive DTLarchive.py');
  setLine('all_27', 'cd /d "{DTLI18N}"');
  setLine('all_28', 'python "{ROOT}\\DTLmenu\\DTLversion.py" begin "{DTLI18N}" DTLi18n');
  setLine('all_29', 'python -m PyInstaller --onefile --console --name DTLi18n DTLi18n.py');
  setLine('all_30', 'Compilation terminee pour tous les outils, dont DTLi18n.');

  setLine('pyi_1', 'cd /d "{ROOT}"');
  setLine('pyi_2', 'python --version');
  setLine('pyi_3', 'python -m PyInstaller --version');
  setLine('pyi_4', 'Si PyInstaller manque, DTLmenu proposera : python -m pip install --upgrade pyinstaller');

  document.getElementById('f-dkw').innerText   = p.DKW  + '\\dist';
  document.getElementById('f-dsw').innerText   = p.DSW  + '\\dist';
  document.getElementById('f-gdtl').innerText  = p.GDTL + '\\dist';
  document.getElementById('f-ghm').innerText   = p.GHM  + '\\dist';
  document.getElementById('f-dta').innerText   = p.DTA  + '\\dist';
  document.getElementById('f-dt4u').innerText  = p.DT4U + '\\dist';
  document.getElementById('f-dtlar').innerText = p.DTLAR + '\\dist';
  document.getElementById('f-dtli18n').innerText = p.DTLI18N + '\\dist';
  document.getElementById('f-root').innerText  = p.ROOT;
}

function applyRoot() {
  var root = normalizePath(document.getElementById('root-dir').value);
  document.getElementById('root-dir').value = root;
  var missing = missingRequiredTools(root);
  if (missing.length > 0) {
    setRootStatus('Dossier outils incomplet : ' + missing.join(', '), false);
    alert('Impossible de valider ce dossier outils.\n\nElements manquants :\n' + missing.join('\n'));
    return false;
  }
  saveRoot(root);
  setRootStatus('Dossier outils valide : ' + root, true);
  renderAll();
  return true;
}

function show(id) {
  var all = document.body.getElementsByTagName('div');
  var i, el;
  for (i = 0; i < all.length; i++) {
    el = all[i];
    if (el.id && el.id.indexOf('screen-') === 0) {
      el.className = 'screen';
    }
  }
  el = document.getElementById('screen-' + id);
  if (el) el.className = 'screen-active';
}

function buildScript(blockId, title) {
  var el = document.getElementById(blockId);
  if (!el) return '';
  var lines = [];
  lines.push('@echo off');
  lines.push('title ' + cmdText(title));
  lines.push('echo ' + cmdText(title));
  lines.push('echo ================================================================');
  lines.push('echo.');

  var spans = el.getElementsByTagName('span');
  for (var i = 0; i < spans.length; i++) {
    var t   = spans[i].innerText;
    var cls = spans[i].className;
    if (!t) continue;
    if (cls === 'dtl-cmd-comment') {
      lines.push('rem ' + cmdText(t));
    } else if (cls === 'dtl-cmd-echo') {
      lines.push('echo ' + cmdText(t));
    } else if (cls === 'dtl-cmd-line') {
      if (t.indexOf('DTLversion.py" begin ') >= 0) {
        lines.push('set "DTL_ROLLBACK=' + t.replace(' begin ', ' rollback ') + '"');
      }
      lines.push(t);
      if (t.indexOf('python') === 0) {
        lines.push('if errorlevel 1 goto :error');
      }
    }
  }

  lines.push('echo.');
  lines.push('echo Operation terminee.');
  lines.push('goto :end');
  lines.push(':error');
  lines.push('if defined DTL_ROLLBACK call %DTL_ROLLBACK%');
  lines.push('set "DTL_ROLLBACK="');
  lines.push('echo.');
  lines.push('echo ERREUR : la derniere commande a echoue.');
  lines.push(':end');
  lines.push('echo.');
  lines.push('pause');
  return lines.join('\r\n');
}

function runBlock(blockId, title) {
  if (!ensureValidRoot()) return;
  if (!ensurePyInstaller()) return;
  var script = buildScript(blockId, title);
  if (!script) return;
  var fso   = getFso();
  var shell = getShell();
  var tmp   = shell.ExpandEnvironmentStrings('%TEMP%');
  var path  = tmp + '\\DTLmenu_run.cmd';
  var f = fso.CreateTextFile(path, true, false);
  f.Write(script);
  f.Close();
  shell.Run('"' + path + '"', 1, false);
}

function openFolder(key) {
  if (!ensureValidRoot()) return;
  var p = getPaths();
  var dirs = { dkw: p.DKW + '\\dist', dsw: p.DSW + '\\dist', gdtl: p.GDTL + '\\dist', ghm: p.GHM + '\\dist', dta: p.DTA + '\\dist', dt4u: p.DT4U + '\\dist', dtlar: p.DTLAR + '\\dist', dtli18n: p.DTLI18N + '\\dist', root: p.ROOT };
  var path = dirs[key];
  if (!path) return;
  var fso = getFso();
  if (fso.FolderExists(path)) {
    var shell = getShell();
    shell.Run('explorer.exe "' + path + '"', 1, false);
  } else {
    alert('Dossier introuvable :\n' + path);
  }
}

sizeApplicationWindow();
if (ensureValidRoot()) {
  ensurePyInstaller();
}
window.scrollTo(0, 0);
</script>
</body>
</html>
